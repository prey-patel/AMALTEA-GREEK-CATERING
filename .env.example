# VITE_SUPABASE_URL: The URL of your Supabase project (used by React)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# VITE_SUPABASE_ANON_KEY: The anonymous API key of your Supabase project (used by React)
VITE_SUPABASE_ANON_KEY="your-anon-key-here"


# =========================================================================
# SUPABASE EDGE FUNCTION SECRETS (BREVO EMAIL NOTIFICATIONS)
# =========================================================================
# These secrets must be configured in your production Supabase project
# using the Supabase CLI command: supabase secrets set KEY=VALUE
# or via the Supabase Dashboard (Project Settings -> API -> Edge Function Secrets).

# BREVO_API_KEY: Your Brevo SMTP API key (v3 API key)
# BREVO_API_KEY="xkeysib-..."

# BREVO_SENDER_EMAIL: The verified sender email address in Brevo
# BREVO_SENDER_EMAIL="notifications@yourdomain.com"

# BREVO_SENDER_NAME: The human-readable name of the sender
# BREVO_SENDER_NAME="Amaltea Catering"

# ADMIN_INQUIRY_EMAIL: Recipient list for admin notifications (comma-separated)
# ADMIN_INQUIRY_EMAIL="catering@amaltea.com.pl"

